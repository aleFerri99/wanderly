NEXT_PUBLIC_SUPABASE_URL=https://tocvrknzhhnvuumoxvwj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InRvY3Zya256aGhudnV1bW94dndqIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODIxMzc0OTIsImV4cCI6MjA5NzcxMzQ5Mn0.VXB41I8fEsLXFwB_hBNYjHok1tFVCd15BStcLGBCgsU

# URL pubblico dell'app (usato per OAuth redirect e invite links)
# In development: http://localhost:3000
# In produzione: https://tuodominio.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google AI Studio — chiave gratuita per Smart Scheduling (Modulo H)
# Ottieni la tua su: https://aistudio.google.com/apikey
# Se non configurata, lo scheduling usa il fallback matematico automaticamente
GOOGLE_AI_KEY=la-tua-chiave-google-ai-studio

# OpenTripMap API key — arricchimento dati attività per il Travel Planner
# Registrati gratis su https://dev.opentripmap.org
# Free tier: 5.000 richieste/giorno, caching dei risultati permesso
# Overpass API (OpenStreetMap) non richiede API key
OPENTRIPMAP_API_KEY=

# Geoapify API key — autocomplete intelligente nel form aggiunta attività
# Registrati gratis su https://www.geoapify.com (no carta di credito)
# Free tier: 3.000 richieste/giorno, ~90.000/mese
# Se vuota, il sistema usa Nominatim come fallback (nessun key necessario)
NEXT_PUBLIC_GEOAPIFY_KEY=f9168204744746d8b72b47f50e9ec888
