# Expo espone al bundle solo le variabili con prefisso EXPO_PUBLIC_
# Copia in .env.local e riempi con gli stessi valori del web (apps/web/.env.local)

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Geoapify (autocomplete, geocoding, routing mappe) — stessa chiave del web
EXPO_PUBLIC_GEOAPIFY_KEY=
